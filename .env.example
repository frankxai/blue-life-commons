# Blue Life Commons media storage configuration.
# Do not put real secrets in this file. Copy required values into Vercel
# environment variables or a local untracked .env file.

# Public read model
BLC_MEDIA_STORAGE_PROVIDER=cloudflare_r2
BLC_MEDIA_PUBLIC_BASE_URL=https://media.bluelifecommons.org
BLC_MEDIA_PRODUCTION_BUCKET=blue-life-media-prod
BLC_MEDIA_STAGING_BUCKET=blue-life-media-staging
BLC_MEDIA_REVIEW_BUCKET=blue-life-media-review

# S3-compatible write path for Cloudflare R2.
# R2 endpoint format is documented by Cloudflare:
# https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCOUNT_ID=replace-with-cloudflare-account-id
R2_ENDPOINT=https://replace-with-cloudflare-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=replace-with-r2-access-key-id
R2_SECRET_ACCESS_KEY=replace-with-r2-secret-access-key

# Optional future database/API layer.
MEDIA_DATABASE_URL=replace-with-postgres-connection-url
MEDIA_SIGNING_SECRET=replace-with-random-signing-secret
