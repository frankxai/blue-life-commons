# Blue Life Commons media storage configuration.
# Do not put real secrets in this file. Copy required values into Vercel
# environment variables or a local untracked .env file.

# Public read model
BLC_MEDIA_STORAGE_PROVIDER=vercel_blob
BLC_MEDIA_PRODUCTION_STORE=blue-life-commons-media

# Vercel Blob write path.
# Prefer Vercel OIDC at runtime. Use BLOB_READ_WRITE_TOKEN for local batch uploads.
BLOB_READ_WRITE_TOKEN=replace-with-vercel-blob-read-write-token
BLOB_STORE_ID=replace-with-vercel-blob-store-id
VERCEL_OIDC_TOKEN=provided-by-vercel-runtime

# Optional future database/API layer.
MEDIA_DATABASE_URL=replace-with-postgres-connection-url
MEDIA_SIGNING_SECRET=replace-with-random-signing-secret
