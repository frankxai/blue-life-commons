{
  "name": "blue-life-commons",
  "version": "1.0.0",
  "description": "Blue Life Commons — the open intelligence commons for ocean life.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next typegen && tsc --noEmit",
    "typecheck": "next typegen && tsc --noEmit",
    "media:storage": "python scripts/build_species_media_storage_manifest.py",
    "media:storage:check": "python scripts/build_species_media_storage_manifest.py --check",
    "media:blob:plan": "node scripts/upload_species_media_to_vercel_blob.mjs",
    "media:blob:upload": "node scripts/upload_species_media_to_vercel_blob.mjs --write",
    "media:blob:check": "node scripts/upload_species_media_to_vercel_blob.mjs --check"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/frankxai/blue-life-commons.git"
  },
  "license": "CC-BY-4.0",
  "dependencies": {
    "@vercel/blob": "^2.5.0",
    "gray-matter": "^4.0.3",
    "marked": "^18.0.5",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "server-only": "^0.0.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "postcss": "8.5.16",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "postcss": "8.5.16"
  }
}
